#!/usr/bin/env bash
# ==============================================================================
# setup/arch-devenv — Provisiona um ambiente de desenvolvimento no container Arch
# ------------------------------------------------------------------------------
# Instala pacotes essenciais, Zsh + Oh-My-Zsh + plugins, pyenv + Python e VS Code.
#
# ⚠ ONDE RODAR: DENTRO do container Arch criado com distrobox (ex.: `distrobox
#   enter arch`), NÃO no host SteamOS. Ele usa pacman/AUR, que não existem no host.
#
# Escopo: dentro do container (persiste enquanto o container existir).
#
# Uso:    ./arch-devenv [-h|--help]
# ==============================================================================

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

case "${1:-}" in
    -h|--help)
        echo "Provisiona ambiente de dev (Zsh, pyenv, VS Code) dentro do container Arch."
        echo "Uso: $(basename "$0")"
        exit 0
        ;;
esac

# Versão do Python a instalar via pyenv (troque aqui se quiser outra).
PYTHON_VERSION="3.13.0"

banner "CONFIGURAÇÃO AUTOMÁTICA — AMBIENTE ARCH"
log_warn "Rode este script DENTRO do container Arch (distrobox), não no host."

# ------------------------------------------------------------------------------
# 0. SENHA (SUDO)
# ------------------------------------------------------------------------------
log_info "Passo 0: Verificando permissões de administrador (sudo)..."
USER_PASS_STATUS="$(passwd -S "$(whoami)" 2>/dev/null | awk '{print $2}')"
if [ "$USER_PASS_STATUS" = "NP" ]; then
    log_warn "Você ainda não tem senha para o usuário '$(whoami)'. Defina uma agora:"
    if ! passwd; then
        log_err "Falha ao definir a senha. Abortando."
        exit 1
    fi
    log_ok "Senha definida!"
else
    log_ok "Usuário já possui senha."
fi

log_info "Validando acesso sudo..."
if sudo -v; then
    log_ok "Acesso sudo confirmado."
else
    log_err "Não foi possível autenticar com sudo."
    exit 1
fi

# ------------------------------------------------------------------------------
# 1. PACOTES ESSENCIAIS
# ------------------------------------------------------------------------------
log_info "Passo 1: Instalando pacotes essenciais..."
PACKAGES=(
    git curl base-devel dkms perl xz libffi
    wget pulseaudio gcc make mariadb-libs
    openssl zlib bzip2 readline sqlite llvm
    ncurses python-pyopenssl tk fastfetch nano
    gnome-keyring zsh
)
if sudo pacman -S --needed --noconfirm "${PACKAGES[@]}"; then
    log_ok "Pacotes essenciais verificados/instalados."
else
    log_err "Problema na instalação dos pacotes. Verifique sua conexão."
    exit 1
fi

# ------------------------------------------------------------------------------
# 2. ZSH COMO SHELL PADRÃO
# ------------------------------------------------------------------------------
log_info "Passo 2: Configurando Zsh como shell padrão..."
if [[ "${SHELL:-}" == */zsh ]]; then
    log_ok "O shell padrão já é o Zsh."
else
    if sudo chsh -s "$(command -v zsh)" "$(whoami)"; then
        log_ok "Shell alterado para Zsh."
    else
        log_warn "Não foi possível alterar o shell automaticamente."
    fi
fi

# ------------------------------------------------------------------------------
# 3. OH-MY-ZSH + PLUGINS
# ------------------------------------------------------------------------------
OMZ_DIR="$HOME/.oh-my-zsh"
if [ -d "$OMZ_DIR" ]; then
    log_ok "Oh-My-Zsh já está instalado."
else
    log_info "Instalando Oh-My-Zsh..."
    # KEEP_ZSHRC=yes => não sobrescreve um .zshrc existente.
    KEEP_ZSHRC=yes RUNZSH=no CHSH=no \
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

clone_plugin() {
    local name="$1" url="$2" dest="$ZSH_CUSTOM/plugins/$1"
    if [ -d "$dest" ]; then
        log_ok "Plugin $name já existe."
    else
        log_info "Baixando $name..."
        git clone --depth 1 "$url" "$dest" || log_warn "Falha ao clonar $name."
    fi
}
clone_plugin zsh-syntax-highlighting https://github.com/zsh-users/zsh-syntax-highlighting.git
clone_plugin zsh-autosuggestions     https://github.com/zsh-users/zsh-autosuggestions.git

# ------------------------------------------------------------------------------
# 4. .zshrc (NÃO-DESTRUTIVO)
# ------------------------------------------------------------------------------
log_info "Passo 4: Ajustando .zshrc (preservando o que já existe)..."
ZSHRC_FILE="$HOME/.zshrc"
MARKER_BEGIN="# >>> DECK_DEVENV >>>"
MARKER_END="# <<< DECK_DEVENV <<<"

# Define/atualiza uma linha de config sem apagar o resto do arquivo.
set_zshrc_value() {
    local key="$1" line="$2" file="$3"
    if grep -q "^$key" "$file" 2>/dev/null; then
        sed -i "s|^$key.*|$line|" "$file"
    else
        printf '%s\n' "$line" >> "$file"
    fi
}

# Backup por segurança.
[ -f "$ZSHRC_FILE" ] && cp "$ZSHRC_FILE" "$ZSHRC_FILE.bkp.$(date +%s)"

if [ ! -f "$ZSHRC_FILE" ]; then
    log_act "Criando .zshrc inicial..."
    cat > "$ZSHRC_FILE" <<'EOF'
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="bira"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh
EOF
elif ! grep -q 'oh-my-zsh.sh' "$ZSHRC_FILE"; then
    log_act "Adicionando carregamento do Oh-My-Zsh ao .zshrc existente..."
    cat >> "$ZSHRC_FILE" <<'EOF'

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="bira"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh
EOF
else
    set_zshrc_value 'ZSH_THEME=' 'ZSH_THEME="bira"' "$ZSHRC_FILE"
    set_zshrc_value 'plugins=' 'plugins=(git zsh-autosuggestions zsh-syntax-highlighting)' "$ZSHRC_FILE"
fi

# Bloco gerenciado: correção do gnome-keyring no Distrobox (idempotente).
if ! grep -qF "$MARKER_BEGIN" "$ZSHRC_FILE" 2>/dev/null; then
    log_act "Adicionando bloco do gnome-keyring ao .zshrc..."
    cat >> "$ZSHRC_FILE" <<EOF

$MARKER_BEGIN
# Bloco gerenciado pelo arch-devenv — correção do gnome-keyring no Distrobox.
export GNOME_KEYRING_CONTROL="\$HOME/.cache/keyring-local"
mkdir -p "\$GNOME_KEYRING_CONTROL"
chmod 700 "\$GNOME_KEYRING_CONTROL"
eval "\$(gnome-keyring-daemon --start --components=secrets,ssh,pkcs11 2>/dev/null)"
export SSH_AUTH_SOCK
export GNOME_KEYRING_CONTROL
$MARKER_END
EOF
else
    log_skip "Bloco do gnome-keyring já presente no .zshrc."
fi
log_ok ".zshrc ajustado."

# ------------------------------------------------------------------------------
# 5. PYENV + PYTHON
# ------------------------------------------------------------------------------
log_info "Passo 5: Instalando pyenv + Python $PYTHON_VERSION..."
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"

if [ -d "$PYENV_ROOT" ]; then
    log_ok "Pyenv já está instalado."
else
    log_info "Instalando pyenv..."
    curl -fsSL https://pyenv.run | bash || log_warn "Falha ao instalar pyenv."
fi

if require_cmd pyenv; then
    eval "$(pyenv init -)"
    if pyenv versions --bare 2>/dev/null | grep -qx "$PYTHON_VERSION"; then
        log_ok "Python $PYTHON_VERSION já instalado."
    else
        log_info "Instalando Python $PYTHON_VERSION (pode demorar)..."
        pyenv install "$PYTHON_VERSION" && pyenv global "$PYTHON_VERSION"
    fi
    python -c 'import tkinter; print("Tkinter OK")' 2>/dev/null || log_warn "Tkinter pode não estar ativo."
else
    log_warn "pyenv não disponível no PATH — pulei a instalação do Python."
fi

# ------------------------------------------------------------------------------
# 6. VS CODE (AUR)
# ------------------------------------------------------------------------------
log_info "Passo 6: Verificando Visual Studio Code..."
if require_cmd code; then
    log_ok "Visual Studio Code já está instalado."
elif [ "$(id -u)" -eq 0 ]; then
    log_warn "makepkg não roda como root — pulei o VS Code. Rode como usuário normal."
else
    log_info "Instalando VS Code via AUR..."
    BUILD_DIR="$HOME/Downloads/vscode-build"
    rm -rf "$BUILD_DIR"
    mkdir -p "$BUILD_DIR"
    if git clone --depth 1 https://aur.archlinux.org/visual-studio-code-bin.git "$BUILD_DIR/visual-studio-code-bin"; then
        # subshell: o cd não "vaza" e um erro não nos deixa preso em outro diretório.
        if ( cd "$BUILD_DIR/visual-studio-code-bin" && makepkg -si --noconfirm ); then
            log_ok "VS Code instalado."
        else
            log_warn "Falha ao compilar/instalar o VS Code."
        fi
    else
        log_warn "Falha ao clonar o repositório AUR do VS Code."
    fi
    rm -rf "$BUILD_DIR"
fi

# ------------------------------------------------------------------------------
# 7. FINALIZAÇÃO
# ------------------------------------------------------------------------------
echo ""
banner "PROCESSO CONCLUÍDO" "$GREEN"
log_info "Abra um novo terminal (ou rode 'exec zsh') para aplicar o Zsh e as mudanças."
